#include <iostream>
#include <cstring>

using namespace std;

int main() {
    int n;
    cout << "Ingrese el numero de cadenas: ";
    cin >> n;
    cin.ignore(); 

    char cadena[100];
    cout << "Ingrese las " << n << " cadenas:\n";

    for (int i = 0; i < n; i++) {
        cout << "[" << i + 1 << "]: ";
        cin.getline(cadena, 100);

        if (cadena[0] == 'b' || cadena[0] == 'B') {
            cout << "-> Comienza con 'b': " << cadena << endl;
        }
    }

    return 0;
}
