#include <iostream>
#include <cstring>

using namespace std;

int main() {
    int n;
    cout << "Ingrese el numero de cadenas: ";
    cin >> n;
    cin.ignore();

    char cadena[100];
    char* ptr_cadena = cadena; 
    cout << "Ingrese las " << n << " cadenas:\n";

    for (int i = 0; i < n; i++) {
        cout << "[" << i + 1 << "]: ";
        cin.getline(ptr_cadena, 100);

        if (*ptr_cadena == 'b' || *ptr_cadena == 'B') {
            cout << "-> Comienza con 'b': " << ptr_cadena << endl;
        }
    }

    return 0;
}
